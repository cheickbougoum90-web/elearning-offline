<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quiz</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-blue-100 min-h-screen">
<header class="bg-white shadow-sm">
    <div class="max-w-5xl mx-auto p-4 flex justify-between items-center">
        <h1 id="quizTitre" class="text-xl font-bold text-blue-600">🧠 Quiz</h1>
        <a href="javascript:history.back()" class="text-gray-500 text-sm hover:text-blue-600">← Retour</a>
    </div>
</header>

<main class="max-w-3xl mx-auto p-6" id="quizContainer">
    <div class="text-center text-gray-400 py-10">Chargement du quiz...</div>
</main>

<script src="js/api.js"></script>
<script>
requireAuth();

const params    = new URLSearchParams(window.location.search);
const leconId   = params.get("lecon_id");
const leconTitre = params.get("lecon_titre");
let quizData    = [];
let currentIdx  = 0;
let score       = 0;

if (leconTitre) {
    document.getElementById("quizTitre").innerText = "🧠 Quiz — " + decodeURIComponent(leconTitre);
}

async function loadQuiz() {
    const container = document.getElementById("quizContainer");
    if (!leconId) {
        container.innerHTML = `<p class="text-red-400 text-center">Leçon non spécifiée.</p>`;
        return;
    }
    try {
        quizData = await getQuiz(leconId);
        if (!quizData || quizData.length === 0) {
            container.innerHTML = `<div class="bg-white rounded-2xl shadow p-8 text-center">
                <p class="text-gray-500 text-lg">Aucun quiz pour cette leçon.</p>
                <a href="javascript:history.back()" class="mt-4 inline-block text-blue-600 hover:underline">← Retour</a>
            </div>`;
            return;
        }
        afficherQuestion(0);
    } catch(e) {
        container.innerHTML = `<p class="text-red-400 text-center">Erreur de chargement.</p>`;
    }
}

function afficherQuestion(idx) {
    const container = document.getElementById("quizContainer");
    const q = quizData[idx];
    container.innerHTML = `
        <div class="bg-white rounded-2xl shadow p-6">
            <div class="flex justify-between text-sm text-gray-400 mb-4">
                <span>Question ${idx + 1} / ${quizData.length}</span>
                <span>Score : ${score} / ${idx}</span>
            </div>
            <h2 class="text-xl font-bold mb-6">${q.question}</h2>
            <div class="space-y-3" id="reponsesContainer">
                ${q.reponses.map(r => `
                    <label class="block border rounded-xl p-4 cursor-pointer hover:bg-blue-50 transition"
                           id="label-${r.id}">
                        <input type="radio" name="reponse" value="${r.id}" class="mr-2">
                        ${r.texte}
                    </label>
                `).join("")}
            </div>
            <button onclick="validerReponse(${q.id})"
                class="mt-6 w-full bg-blue-600 text-white py-3 rounded-xl hover:bg-blue-700 font-semibold">
                Valider
            </button>
            <div id="resultatQ" class="mt-4 hidden"></div>
        </div>
    `;
}

async function validerReponse(quizId) {
    const selected = document.querySelector('input[name="reponse"]:checked');
    const resultat = document.getElementById("resultatQ");

    if (!selected) {
        resultat.innerHTML = `<p class="text-orange-500">Sélectionne une réponse.</p>`;
        resultat.classList.remove("hidden");
        return;
    }

    // Désactiver les boutons
    document.querySelectorAll('input[name="reponse"]').forEach(i => i.disabled = true);
    document.querySelector("button[onclick]").disabled = true;

    try {
        const res = await soumettreReponse(quizId, parseInt(selected.value));

        if (res.correct) {
            score++;
            selected.parentElement.className = "block border-2 border-green-500 bg-green-50 rounded-xl p-4";
            resultat.innerHTML = `<div class="bg-green-100 text-green-700 p-4 rounded-xl">✅ ${res.message}</div>`;
        } else {
            selected.parentElement.className = "block border-2 border-red-400 bg-red-50 rounded-xl p-4";
            resultat.innerHTML = `<div class="bg-red-100 text-red-700 p-4 rounded-xl">❌ ${res.message}</div>`;
        }
        resultat.classList.remove("hidden");

        // Bouton suivant après 1.5s
        setTimeout(() => {
            currentIdx++;
            if (currentIdx < quizData.length) {
                afficherQuestion(currentIdx);
            } else {
                afficherResultatFinal();
            }
        }, 1500);

    } catch(e) {
        resultat.innerHTML = `<p class="text-red-500">Erreur : ${e.message}</p>`;
        resultat.classList.remove("hidden");
    }
}

async function afficherResultatFinal() {
    const container = document.getElementById("quizContainer");
    const pct = Math.round((score / quizData.length) * 100);
    const emoji = pct >= 80 ? "🎉" : pct >= 50 ? "👍" : "💪";

    // Enregistrer la progression avec le VRAI score du quiz
    try {
        await saveProgression(parseInt(leconId), "termine", pct);
    } catch(e) {
        console.error("Erreur sauvegarde progression:", e);
    }

    container.innerHTML = `
        <div class="bg-white rounded-2xl shadow p-8 text-center">
            <div class="text-6xl mb-4">${emoji}</div>
            <h2 class="text-2xl font-bold mb-2">Quiz terminé !</h2>
            <p class="text-gray-500 mb-4">Score final : <strong>${score} / ${quizData.length}</strong> (${pct}%)</p>
            <div class="w-full bg-gray-200 rounded-full h-4 mb-6">
                <div class="bg-blue-600 h-4 rounded-full transition-all" style="width:${pct}%"></div>
            </div>
            <a href="javascript:history.back()"
                class="bg-blue-600 text-white px-8 py-3 rounded-xl hover:bg-blue-700 inline-block">
                ← Retour à la leçon
            </a>
        </div>
    `;
}

loadQuiz();
</script>
</body>
</html>
