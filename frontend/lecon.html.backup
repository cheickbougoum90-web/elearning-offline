<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Leçon</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
@keyframes fadeIn { from { opacity:0; transform:translateY(15px); } to { opacity:1; transform:translateY(0); } }
.fade-in { animation: fadeIn 0.6s ease-out; }
</style>
</head>
<body class="bg-gradient-to-br from-blue-50 via-white to-blue-100 min-h-screen">
<header class="bg-white shadow-sm">
    <div class="max-w-6xl mx-auto p-4 flex justify-between items-center">
        <h1 id="coursTitre" class="text-blue-600 font-bold text-xl">📚 Cours</h1>
        <a href="cours.html" class="text-gray-600 hover:text-blue-600 text-sm">← Retour aux cours</a>
    </div>
</header>

<main class="max-w-5xl mx-auto p-6 fade-in">

    <!-- LISTE DES LEÇONS -->
    <div id="leconsList" class="space-y-4 mb-8">
        <div class="text-center text-gray-400 py-10">Chargement des leçons...</div>
    </div>

    <!-- CONTENU LEÇON SÉLECTIONNÉE -->
    <div id="leconContent" class="hidden">
        <div class="bg-white rounded-2xl shadow p-6 mb-6">
            <h2 id="leconTitre" class="text-2xl font-bold mb-4"></h2>

            <!-- BARRE DE PROGRESSION -->
            <div class="mb-6">
                <div class="flex justify-between text-sm text-gray-500 mb-1">
                    <span>Progression du cours</span>
                    <span id="progressPct">0%</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-3">
                    <div id="progressBar" class="bg-blue-600 h-3 rounded-full transition-all" style="width:0%"></div>
                </div>
            </div>

            <div id="leconTexte" class="text-gray-700 leading-8"></div>
        </div>

        <!-- BOUTONS ACTION -->
        <div class="flex gap-4 justify-between">
            <button onclick="marquerTermine()"
                class="bg-green-600 text-white px-6 py-3 rounded-xl hover:bg-green-700">
                ✅ Marquer comme terminée
            </button>
            <button id="btnQuiz" onclick="allerQuiz()"
                class="bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700 hidden">
                Passer au Quiz →
            </button>
        </div>
        <p id="actionMsg" class="mt-3 text-sm text-gray-500"></p>
    </div>
</main>

<script src="js/api.js"></script>
<script>
requireAuth();

const params   = new URLSearchParams(window.location.search);
const coursId  = params.get("cours_id");
const coursTitre = params.get("cours_titre");

let leconActive = null;
let toutesLecons = [];

if (coursTitre) {
    document.getElementById("coursTitre").innerText = "📚 " + decodeURIComponent(coursTitre);
}

async function loadLecons() {
    const container = document.getElementById("leconsList");
    if (!coursId) {
        container.innerHTML = `<p class="text-red-400 text-center">Cours non spécifié.</p>`;
        return;
    }
    try {
        toutesLecons = await getLecons(coursId);
        if (!toutesLecons || toutesLecons.length === 0) {
            container.innerHTML = `<p class="text-gray-400 text-center py-10">Aucune leçon disponible.</p>`;
            return;
        }
        container.innerHTML = toutesLecons.map((l, i) => `
            <div onclick="ouvrirLecon(${l.id})"
                class="bg-white p-4 rounded-xl shadow hover:shadow-md cursor-pointer flex justify-between items-center transition hover:-translate-y-0.5"
                id="lecon-card-${l.id}">
                <div class="flex items-center gap-3">
                    <span class="w-8 h-8 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center font-bold text-sm">
                        ${i + 1}
                    </span>
                    <span class="font-medium text-gray-800">${l.titre}</span>
                </div>
                <span class="text-gray-400 text-sm">→</span>
            </div>
        `).join("");
    } catch(e) {
        container.innerHTML = `<p class="text-red-400 text-center">Erreur de chargement.</p>`;
    }
}

async function ouvrirLecon(id) {
    leconActive = toutesLecons.find(l => l.id === id);
    if (!leconActive) return;

    document.getElementById("leconTitre").innerText = leconActive.titre;
    document.getElementById("leconTexte").innerText = leconActive.contenu || "Contenu en cours de rédaction.";
    document.getElementById("leconContent").classList.remove("hidden");

    // Vérifier si un quiz existe
    const quiz = await getQuiz(id);
    if (quiz && quiz.length > 0) {
        document.getElementById("btnQuiz").classList.remove("hidden");
    } else {
        document.getElementById("btnQuiz").classList.add("hidden");
    }

    // Mettre à jour la progression affichée
    await updateProgressBar();

    // Scroll vers le contenu
    document.getElementById("leconContent").scrollIntoView({ behavior: "smooth" });
}

async function updateProgressBar() {
    const userId = localStorage.getItem("user_id");
    try {
        const stats = await getStats(userId, coursId);
        const pct   = stats.pourcentage || 0;
        document.getElementById("progressBar").style.width = pct + "%";
        document.getElementById("progressPct").innerText = pct + "%";
    } catch(e) {}
}

async function marquerTermine() {
    if (!leconActive) return;
    const msg = document.getElementById("actionMsg");
    try {
        await saveProgression(leconActive.id, "termine", 0);
        msg.innerText = "✅ Leçon marquée comme terminée !";
        msg.className = "mt-3 text-sm text-green-600";
        await updateProgressBar();
    } catch(e) {
        msg.innerText = "Erreur : " + e.message;
        msg.className = "mt-3 text-sm text-red-500";
    }
}

function allerQuiz() {
    window.location.href = `quiz.html?lecon_id=${leconActive.id}&lecon_titre=${encodeURIComponent(leconActive.titre)}`;
}

loadLecons();
</script>
</body>
</html>
